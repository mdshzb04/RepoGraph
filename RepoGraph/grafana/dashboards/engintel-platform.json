{
  "title": "EngIntel Platform",
  "uid": "engintel-platform",
  "tags": ["engintel", "opentelemetry"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "description": "Live OpenTelemetry metrics from the EngIntel backend. Cumulative counters and rates; panels use `or vector(0)` for low-traffic environments.",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "API & availability",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Total API requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_api_request_total[$__range])) or vector(0)",
          "legendFormat": "requests"
        }
      ],
      "fieldConfig": {
        "defaults": { "noValue": "0", "color": { "mode": "fixed", "fixedColor": "blue" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Request rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(engintel_api_request_total[5m])) or vector(0)",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Error rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * sum(rate(engintel_api_request_errors[5m])) / (sum(rate(engintel_api_request_total[5m])) + 1e-9) or vector(0)",
          "legendFormat": "%"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "API latency (avg)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(engintel_api_request_duration_sum[5m])) / sum(rate(engintel_api_request_duration_count[5m])) or vector(0)",
          "legendFormat": "ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "Platform uptime signal",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_platform_uptime[$__range])) or vector(0)",
          "legendFormat": "ticks"
        }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "API request rate (time series)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(engintel_api_request_total[$__rate_interval])) or vector(0)",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "noValue": "0" } }
    },
    {
      "id": 7,
      "title": "API latency (time series)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(engintel_api_request_duration_sum[$__rate_interval])) / sum(rate(engintel_api_request_duration_count[$__rate_interval])) or vector(0)",
          "legendFormat": "avg ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "noValue": "0" } }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Indexing & repository activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "id": 8,
      "title": "Jobs completed (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_repo_index_completed_total[$__range])) or vector(0)",
          "legendFormat": "jobs"
        }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 9,
      "title": "Files indexed (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_repo_index_files[$__range])) or vector(0)",
          "legendFormat": "files"
        }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 10,
      "title": "Chunks indexed (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_repo_index_chunks[$__range])) or vector(0)",
          "legendFormat": "chunks"
        }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 11,
      "title": "Index duration (avg per run)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "avg(engintel_repo_index_duration_ms) or vector(0)",
          "legendFormat": "ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 12,
      "title": "Per-run throughput (files & chunks)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (run_id) (engintel_repo_index_files_total) or vector(0)",
          "legendFormat": "files {{run_id}}"
        },
        {
          "expr": "sum by (run_id) (engintel_repo_index_chunks_total) or vector(0)",
          "legendFormat": "chunks {{run_id}}"
        }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } }
    },
    {
      "id": 13,
      "title": "Index duration (ms per run)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (run_id) (engintel_repo_index_duration_ms) or vector(0)",
          "legendFormat": "{{run_id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "noValue": "0" } }
    },
    {
      "id": 300,
      "type": "row",
      "title": "AI, vector search & traces",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },
    {
      "id": 14,
      "title": "OpenAI tokens (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_openai_tokens[$__range])) or vector(0)",
          "legendFormat": "tokens"
        }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 15,
      "title": "OpenAI requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_openai_requests[$__range])) or vector(0)",
          "legendFormat": "calls"
        }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 16,
      "title": "Est. cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_openai_tokens[$__range])) * 0.3 / 1000000 or vector(0)",
          "legendFormat": "USD"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 17,
      "title": "Vector searches",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_vector_search_total[$__range])) or vector(0)",
          "legendFormat": "searches"
        }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 18,
      "title": "Vector search latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(engintel_vector_search_duration_sum[$__rate_interval])) / sum(rate(engintel_vector_search_duration_count[$__rate_interval])) or vector(0)",
          "legendFormat": "avg ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "noValue": "0" } }
    },
    {
      "id": 19,
      "title": "Trace / activity events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(engintel_traces_events[$__rate_interval])) or vector(0)",
          "legendFormat": "events"
        }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } }
    }
  ]
}
