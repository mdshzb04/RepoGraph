PORT=8000
HOST=0.0.0.0
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
# Required — without a token GitHub’s anonymous API rate-limits indexing quickly
GITHUB_TOKEN=ghp_your_github_pat
FRONTEND_URL=http://localhost:3000
# Comma-separated list for multiple origins in production
# CORS_ORIGINS=https://your-app.com,https://www.your-app.com

# Optional — when set, the FastAPI server requires matching header x-engintel-internal
# from the Next.js server (ENGINTEL_INTERNAL_SECRET in frontend/.env.local).
# ENGINTEL_INTERNAL_SECRET=

# --- Grafana Cloud (OpenTelemetry OTLP / HTTP protobuf) — optional ---
# Copy instance id + API token from Grafana: Connections → OpenTelemetry / your stack.
# Never commit real values; use backend/.env (gitignored) locally or your host’s secret store.
#
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-south-1.grafana.net/otlp
# GRAFANA_CLOUD_INSTANCE_ID=your_numeric_instance_id
# GRAFANA_CLOUD_API_KEY=glc_your_token
# GRAFANA_CLOUD_DASHBOARD_URL=https://your-stack.grafana.net/dashboards
# GRAFANA_CLOUD_DASHBOARD_TITLE=Engintel Backend Metrics
# GRAFANA_CLOUD_DASHBOARD_UID=engintel-backend-metrics
# Optional: public dashboard URL for auth-free iframe embed in Observability UI
# GRAFANA_CLOUD_EMBED_URL=https://your-stack.grafana.net/public-dashboards/...
# Optional: auto-create public dashboard embed (needs Viewer+ on dashboards, not OTLP token)
# GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_your_service_account_token
# OTEL_SERVICE_NAME=engintel-api
# OTEL_DEPLOYMENT_ENVIRONMENT=production

# Optional: omit GRAFANA_CLOUD_OTLP_REGION if you set OTEL_EXPORTER_OTLP_ENDPOINT above.
