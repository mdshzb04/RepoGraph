PORT=8000
HOST=0.0.0.0

# Neon PostgreSQL (required)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Indexing — fast mode (~1–2 min) is default; set INDEX_MODE=full for deep indexing
# INDEX_MODE=fast
# INDEX_MAX_FILES=40
# INDEX_EMBED_LIMIT=48

# OpenAI — embeddings only (text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OpenAI reasoning fallback (chat/architecture when Claude unavailable)
OPENAI_REASONING_MODEL=gpt-4.1

# Anthropic Claude — primary reasoning (chat, architecture, workflows, analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Legacy alias for OPENAI_REASONING_MODEL
OPENAI_MODEL=gpt-4.1

# Required — without a token GitHub’s anonymous API rate-limits indexing quickly
GITHUB_TOKEN=ghp_your_github_pat
FRONTEND_URL=http://localhost:3000
# Comma-separated list for multiple origins in production
# CORS_ORIGINS=https://your-app.com,https://www.your-app.com

# Optional — when set, the FastAPI server requires matching header x-engintel-internal
# from the Next.js server (ENGINTEL_INTERNAL_SECRET in frontend/.env.local).
# ENGINTEL_INTERNAL_SECRET=

# --- Grafana Cloud OpenTelemetry (OTLP HTTP/protobuf) — optional ---
# Copy from Grafana Cloud → Connections → OpenTelemetry. Never commit real secrets.
#
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-south-1.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic YOUR_BASE64_INSTANCE_ID_AND_TOKEN
# OTEL_SERVICE_NAME=repograph-backend
# OTEL_DEPLOYMENT_ENVIRONMENT=production
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=repograph
# OTEL_TRACES_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=none
# OTEL_NODE_RESOURCE_DETECTORS=env,host,os
#
# Optional dashboard links for Observability UI:
# GRAFANA_CLOUD_DASHBOARD_URL=https://your-stack.grafana.net/dashboards
# GRAFANA_CLOUD_DASHBOARD_UID=your-dashboard-uid
# GRAFANA_CLOUD_EMBED_URL=https://your-stack.grafana.net/public-dashboards/...
#
# Legacy fallback if OTEL_EXPORTER_OTLP_HEADERS is unset:
# GRAFANA_CLOUD_INSTANCE_ID=your_numeric_instance_id
# GRAFANA_CLOUD_API_KEY=glc_your_token
