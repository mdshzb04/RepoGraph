{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express API for the Asset Defense copilot",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch -r ./src/otel-preload.ts src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node -r ./dist/otel-preload.js dist/index.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate-json": "tsx scripts/migrate-json-to-neon.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/openai": "^3.0.64",
    "@engintel/telemetry": "1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@prisma/client": "^6.9.0",
    "ai": "^6.0.184",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.0",
    "prisma": "^6.9.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
